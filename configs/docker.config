# docker.config — kernel config fragment added to the Kleaf defconfig overlays.
# The MINIMAL set of container options that still BOOTS on the SM-A055F.
#
# Copy to: kernel_device_modules-6.6/kernel/configs/docker.config
# and append "docker.config" to the --kernel-defconfig-overlays list (see scripts/04-build-kernel.sh).
#
# DO NOT add SYSVIPC, USER_NS, BRIDGE_NETFILTER, CGROUP_PIDS or CGROUP_DEVICE:
# each one causes an instant pre-console boot hang on this device (see README footnote [A]).
# Everything else Docker checks for is already =y in stock: NET_NS, UTS_NS, NAMESPACES,
# CGROUPS, MEMCG, CGROUP_BPF, BPF_SYSCALL, OVERLAY_FS, FUSE_FS, TUN, SECCOMP, BRIDGE, VETH,
# IP_NF_* , NF_NAT.

CONFIG_PID_NS=y                          # PID namespace  (mandatory for Docker)
CONFIG_IPC_NS=y                          # IPC namespace  (mandatory for Docker)
CONFIG_POSIX_MQUEUE=y                    # satisfies IPC_NS dependency WITHOUT SYSVIPC
CONFIG_NETFILTER_XT_MATCH_ADDRTYPE=y     # harmless; only used if you later attempt bridge NAT
